generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ──── Auth ────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  password      String?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts    Account[]
  sessions    Session[]
  memberships WorkspaceMember[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ──── Workspace ────

model Workspace {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  logo         String?
  customDomain String?  @unique
  pageTitle    String?
  pageTheme    String   @default("dark") // "light" | "dark"
  plan         String   @default("free") // "free" | "pro" | "team"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  members   WorkspaceMember[]
  monitors  Monitor[]
  incidents Incident[]
  channels  NotificationChannel[]
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  role        String   @default("member") // "owner" | "admin" | "member"
  joinedAt    DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
}

// ──── Monitor ────

model Monitor {
  id             String   @id @default(cuid())
  workspaceId    String
  name           String
  url            String
  type           String   @default("http") // "http" | "api_health" | "external_status" | "custom_status"
  method         String   @default("GET")
  expectedStatus Int      @default(200)
  interval       Int      @default(60) // seconds
  timeout        Int      @default(10000) // ms
  headers        String?  // JSON
  body           String?  // JSON
  statusField    String?  @default("status.indicator") // for external/custom status
  okValue        String?  @default("none") // for external/custom status
  provider       String?  // "cloudflare" | "vercel" | "neon" | etc.
  isActive       Boolean  @default(true)
  isPaused       Boolean  @default(false)
  isPublic       Boolean  @default(true) // show on public status page
  consecutiveFails Int    @default(0)
  lastCheckedAt  DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  workspace Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  checks    Check[]
  incidents Incident[]

  @@index([workspaceId])
  @@index([isActive, isPaused, lastCheckedAt])
}

model Check {
  id         String   @id @default(cuid())
  monitorId  String
  status     String   // "up" | "down" | "degraded"
  latency    Int?     // ms
  statusCode Int?
  error      String?
  checkedAt  DateTime @default(now())

  monitor Monitor @relation(fields: [monitorId], references: [id], onDelete: Cascade)

  @@index([monitorId, checkedAt(sort: Desc)])
}

// ──── Incident ────

model Incident {
  id           String    @id @default(cuid())
  workspaceId  String
  monitorId    String?
  title        String
  status       String    @default("investigating") // "investigating" | "identified" | "monitoring" | "resolved"
  autoDetected Boolean   @default(false)
  startedAt    DateTime  @default(now())
  resolvedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  workspace Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  monitor   Monitor?         @relation(fields: [monitorId], references: [id], onDelete: SetNull)
  updates   IncidentUpdate[]

  @@index([workspaceId, startedAt(sort: Desc)])
}

model IncidentUpdate {
  id         String   @id @default(cuid())
  incidentId String
  status     String   // "investigating" | "identified" | "monitoring" | "resolved"
  message    String
  isAuto     Boolean  @default(false) // true = 🤖, false = 👤
  createdAt  DateTime @default(now())

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([incidentId, createdAt])
}

// ──── Notification ────

model NotificationChannel {
  id          String   @id @default(cuid())
  workspaceId String
  type        String   // "slack" | "email"
  config      String   // JSON: { webhookUrl } or { addresses: [] }
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}
